backend/pom.xml.tag
backend/pom.xml.releaseBackup
backend/pom.xml.backup
backend/pom.xml.versionsBackup

# Gradle 缓存
backend/.gradle/
backend/build/

# ==========================================
# 3. 前端配置 (Node/Angular)
# ==========================================
# 依赖
frontend/node_modules/
frontend/dist/
frontend/.angular/

# 日志与缓存
frontend/*.log
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
